# Easy Convert API - Environment Configuration
# Copy this file to .env and adjust values as needed

# Application
APP_NAME="Easy Convert API"
APP_VERSION="0.1.0"
DEBUG=false
LOG_LEVEL=INFO

# API Configuration
API_V1_PREFIX="/api/v1"
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# Redis Configuration
REDIS_URL=redis://localhost:6379/0
REDIS_MAX_CONNECTIONS=10

# File Upload Limits
MAX_FILE_SIZE_MB=100
CHUNK_SIZE_MB=5
TEMP_DIR=/tmp/easy_convert

# Job Processing
JOB_TTL_HOURS=24
JOB_CLEANUP_HOURS=1
MAX_CONVERSION_TIME_SECONDS=300

# Rate Limiting
RATE_LIMIT_UPLOADS_PER_HOUR=100
RATE_LIMIT_CONCURRENT_JOBS_PER_IP=10

# Image Conversion Settings
IMAGE_QUALITY=85

# Worker Settings
WORKER_CONCURRENCY=4
WORKER_POLL_INTERVAL_SECONDS=1

# Observability
STRUCTURED_LOGS=true
